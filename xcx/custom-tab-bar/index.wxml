<view class="tab-bar-container {{isDarkMode ? 'dark-mode' : ''}}" wx:if="{{show}}">

  <view class="tab-bar">
    <view class="tab-bar-item {{selected === index ? 'active' : ''}} {{index === 1 ? 'special-tab' : ''}}" 
          wx:for="{{list}}" 
          wx:key="index" 
          data-path="{{item.pagePath}}" 
          data-index="{{index}}" 
          bindtap="switchTab">
      <view class="icon-wrapper">
        <image class="tab-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}"></image>
      </view>
      <text class="tab-text">{{item.text}}</text>
      <view class="active-dot" wx:if="{{selected === index}}"></view>
    </view>
  </view>
</view>
