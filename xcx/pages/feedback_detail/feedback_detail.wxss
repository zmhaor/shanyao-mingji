.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f9fc;
}

/* 自定义导航栏 */
.custom-nav {
  background: #f8f9fc;
  padding: 10px 12px;
  padding-top: 60px;
  position: relative;
  z-index: 100;
  max-width: 500px;
  width: 100%;
  margin: 0 auto;
  box-sizing: border-box;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
}

.back-btn {
  width: 32px;
  height: 32px;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  position: relative;
  z-index: 10;
}

.back-icon {
  width: 16px;
  height: 16px;
}

.nav-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.placeholder {
  width: 32px;
}

.scroll-wrapper {
  flex: 1;
  padding: 10px;
  box-sizing: border-box;
  max-width: 500px;
  width: 100%;
  margin: 0 auto;
}

.main-feedback {
  background: linear-gradient(145deg, rgba(255,255,255,1) 0%, rgba(248,250,255,0.96) 100%);
  border-radius: 18px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 10px 20px -12px rgba(15,23,42,0.12), inset 0 1px 0 rgba(255,255,255,0.95);
  border: 1px solid rgba(226,232,240,0.7);
}

.fb-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  margin-right: 10px;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 15px;
  color: #333;
  font-weight: 500;
  margin-bottom: 3px;
}

.time {
  font-size: 12px;
  color: #999;
}

.status {
  font-size: 12px;
  padding: 3px 10px;
  border-radius: 10px;
}

.status.pending {
  color: #e6a23c;
  background-color: #fdf6ec;
}

.status.adopted {
  color: #67c23a;
  background-color: #f0f9eb;
}

.status.resolved {
  color: #909399;
  background-color: #f4f4f5;
}

.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4px;
  background: #fef2f2;
  border-radius: 50%;
  margin-right: 6px;
  transition: opacity 0.2s;
}

.delete-btn:active {
  opacity: 0.7;
}

.delete-icon {
  width: 14px;
  height: 14px;
  filter: sepia(100%) hue-rotate(320deg) saturate(300%);
}

.fb-content {
  font-size: 15px;
  color: #444;
  line-height: 1.6;
  margin-bottom: 15px;
  white-space: pre-wrap;
}

.fb-actions {
  display: flex;
  justify-content: flex-end;
  border-top: 0.5px solid #f5f5f5;
  padding-top: 10px;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 5px;
}

.action-icon {
  width: 20px;
  height: 20px;
  margin-right: 6px;
  transition: all 0.2s ease;
}

.action-count {
  font-size: 14px;
}

/* 回复列表 */
.replies-section {
  background: linear-gradient(145deg, rgba(255,255,255,1) 0%, rgba(248,250,255,0.96) 100%);
  border-radius: 18px;
  padding: 16px;
  box-shadow: 0 10px 20px -12px rgba(15,23,42,0.12), inset 0 1px 0 rgba(255,255,255,0.95);
  border: 1px solid rgba(226,232,240,0.7);
}

.section-title {
  font-size: 15px;
  font-weight: bold;
  color: #333;
  margin-bottom: 15px;
  padding-left: 8px;
  border-left: 4px solid #6366f1;
}

.reply-list {
  display: flex;
  flex-direction: column;
}

.reply-item {
  display: flex;
  margin-bottom: 15px;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  margin-right: 10px;
  flex-shrink: 0;
}

.reply-content-box {
  flex: 1;
  background-color: #f8fafc;
  padding: 12px;
  border-radius: 12px;
}

.reply-header {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
}

.reply-name {
  font-size: 13px;
  color: #666;
  font-weight: 500;
  margin-right: 6px;
}

.admin-badge {
  font-size: 10px;
  color: #fff;
  background-color: #6366f1;
  padding: 1px 5px;
  border-radius: 3px;
  margin-right: 6px;
}

.fresh-reply-badge {
  font-size: 10px;
  color: #fff;
  background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
  padding: 1px 6px;
  border-radius: 999px;
  margin-right: 6px;
}

.reply-time {
  font-size: 11px;
  color: #999;
  margin-left: auto;
}

.reply-delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4px;
  margin-left: 8px;
  background: #fef2f2;
  border-radius: 50%;
  transition: opacity 0.2s;
}

.reply-delete-btn:active {
  opacity: 0.7;
}

.reply-delete-icon {
  width: 12px;
  height: 12px;
  filter: sepia(100%) hue-rotate(320deg) saturate(300%);
}

.reply-text {
  font-size: 14px;
  color: #444;
  line-height: 1.5;
  white-space: pre-wrap;
}

/* 底部回复栏 */
.bottom-bar {
  display: flex;
  align-items: center;
  padding: 10px 15px;
  background-color: #fff;
  box-shadow: 0 -2px 5px rgba(0,0,0,0.05);
  padding-bottom: calc(env(safe-area-inset-bottom) + 10px);
  max-width: 500px;
  width: 100%;
  margin: 0 auto;
  box-sizing: border-box;
}

.anonymous-toggle {
  display: flex;
  align-items: center;
  margin-right: 10px;
  flex-shrink: 0;
}

.anonymous-toggle text {
  font-size: 13px;
  color: #666;
  margin-left: 4px;
}

.reply-input {
  flex: 1;
  height: 36px;
  background-color: #f1f5f9;
  border-radius: 18px;
  padding: 0 15px;
  font-size: 14px;
  margin-right: 10px;
}

.send-btn {
  font-size: 15px;
  color: #999;
  padding: 5px 0;
  font-weight: 500;
  transition: color 0.2s;
}

.send-btn.active {
  color: #6366f1;
}
