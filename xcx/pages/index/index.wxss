
@keyframes breathe {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.04); }
}



@keyframes float1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(10px, -15px) scale(1.1); }
  66% { transform: translate(-5px, 7.5px) scale(0.95); }
}

@keyframes float2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-12.5px, -10px) scale(1.08); }
}

@keyframes shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}

/* ---- 页面背景 ---- */
page {
  background: linear-gradient(170deg, #eef2ff 0%, #f0f2f8 40%, #fdf2f8 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  transition: background 0.5s ease;
  background-attachment: fixed;
  background-repeat: no-repeat;
}

/* ========================================
   导航栏
   ======================================== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: linear-gradient(180deg, rgba(238, 242, 255, 0.98) 0%, rgba(240, 242, 248, 0.85) 100%);
  padding: 8px 0px 0px; /* 移除左右内边距 */
  padding-top: calc(env(safe-area-inset-top) + 44px);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  justify-content: center;
}


.nav-content {
  display: flex;
  flex-direction: column;
  gap: 6px; /* 极致压缩间距 */
  max-width: 650px;
  width: 100%;
  padding: 0 16px;
  box-sizing: border-box;
}

.notice-scroll-wrap {
  display: flex;
  align-items: center;
  background: linear-gradient(90deg, rgba(99, 102, 241, 0.08) 0%, rgba(255, 255, 255, 0.5) 100%);
  border-radius: 12px;
  padding: 0 12px;
  height: 26px; /* 极致压缩高度 */
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 0.5px solid rgba(255, 255, 255, 0.8);
}

.notice-mini-icon {
  font-size: 14px;
  margin-right: 8px;
  flex-shrink: 0;
  z-index: 2;
}

.notice-marquee-container {
  flex: 1;
  height: 100%;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
}

.notice-marquee-content {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  animation: marquee 25s linear infinite;
  will-change: transform;
}

.notice-item {
  display: flex;
  align-items: center;
  margin-right: 4em; /* 四个字符间距 */
  flex-shrink: 0;
}

.notice-text {
  font-size: 12px;
  color: #6366f1;
  font-weight: 500;
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); } /* 滚动到一半即完成一轮循环 */
}

.nav-top {
  display: flex;
  align-items: center;
  /* 预留右侧胶囊按钮的空间 */
  padding-right: 90px;
}

.nav-bottom {
  display: flex;
  width: 100%;
  align-items: center;
  gap: 8px;
}

/* 搜索模式返回按钮 */
.search-back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 0.5px solid rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.search-back-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.9);
}

.search-back-arrow {
  font-size: 22px;
  color: #475569;
  font-weight: 300;
  line-height: 1;
  margin-top: -2px;
}

.logo-section {
  display: inline-flex;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 30px;
  padding: 3px 12px 3px 3px;
  border: 0.5px solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
}

.logo-icon {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 5px;
  flex-shrink: 0;
}

.logo-icon image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.logo-text {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 1px;
  white-space: nowrap;
}

.search-box {
  flex: 1;
  height: 36px;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 18px;
  display: flex;
  align-items: center;
  padding: 0 14px;
  gap: 7px;
  border: 0.5px solid rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 2px 8px rgba(99, 102, 241, 0.06),
              inset 0 0.5px 0 rgba(255, 255, 255, 0.8);
  position: relative;
  transition: all 0.3s ease;
}

.search-icon {
  width: 15px;
  height: 15px;
  opacity: 0.5;
}

.search-icon image {
  width: 100%;
  height: 100%;
}

.search-input {
  flex: 1;
  font-size: 13px;
  color: var(--text-primary);
}

.search-placeholder {
  flex: 1;
  font-size: 13px;
  color: rgba(71, 85, 105, 0.72);
}

.clear-icon {
  font-size: 14px;
  color: var(--text-muted);
  padding: 4px;
}



/* ========================================
   主内容区
   ======================================== */
.main-content {
  padding: 0; /* 移除由于父级 padding 导致的偏移 */
  padding-top: calc(env(safe-area-inset-top) + 255px); /* 压缩间距后回缩偏移 */
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 防止页面整体滚动 */
  height: 100vh;
  box-sizing: border-box;
  align-items: center; /* 居中内容区域 */
}

/* 有公告时的额外高度 */
.main-content.has-notice {
  padding-top: calc(env(safe-area-inset-top) + 285px);
}

/* 搜索模式下恢复正常流动高度，且由于标题隐藏，需回缩 padding-top */
.main-content.searching {
  background: #eef2ff;
  height: auto;
  min-height: 100vh;
  overflow: visible;
  padding-top: calc(env(safe-area-inset-top) + 140px) !important;
  padding-bottom: calc(100px + env(safe-area-inset-bottom));
}

/* ---- 固定顶部区域 ---- */
.fixed-top-section {
  flex-shrink: 0;
  padding-bottom: 0px; /* 移除底部间距 */
  background: transparent;
  z-index: 10;
  max-width: 650px;
  width: 100%;
  padding: 0 4px 0 4px;
  box-sizing: border-box;
}

/* ---- 局部滚动容器 ---- */
.scroll-tools-container {
  flex: 1;
  width: 100%;
  max-width: 650px; /* 在此级也进行限制确保对齐 */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  /* 解决 scroll-view 渲染区域问题 */
  height: 0; 
  padding: 0 16px;
  box-sizing: border-box;
}

/* 底部防遮挡留白 */
.bottom-safe-area {
  height: calc(120px + env(safe-area-inset-bottom));
}

/* ---- 装饰光斑 ---- */
.deco-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  filter: blur(30px);
  opacity: 1;
  transition: opacity 0.5s ease;
}

.deco-orb.hidden {
  opacity: 0;
}

.deco-orb-1 {
  width: 150px;
  height: 150px;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
  top: -30px;
  right: -40px;
  animation: float1 8s ease-in-out infinite;
}

.deco-orb-2 {
  width: 120px;
  height: 120px;
  background: radial-gradient(circle, rgba(236, 72, 153, 0.1) 0%, transparent 70%);
  top: 100px;
  left: -30px;
  animation: float2 10s ease-in-out infinite;
}

.deco-orb-3 {
  width: 100px;
  height: 100px;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.08) 0%, transparent 70%);
  bottom: 50px;
  right: 20px;
  animation: float1 12s ease-in-out infinite reverse;
}

.star-icon {
  font-size: 11px;
}

/* ---- 主标题 ---- */
.main-title {
  font-size: 32px;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 12px;
  margin-top: 6px;
  letter-spacing: -0.5px;
  line-height: 1.25;
  position: relative;
  z-index: 1;
}

.highlight {
  background: linear-gradient(90deg, #6366f1 0%, #ec4899 50%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: inline-block;
  margin: 0 3px;
}

.subtitle {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 8px; /* 压缩此处间距 */
  display: block;
  position: relative;
  z-index: 1;
}

/* ========================================
   分类标签
   ======================================== */
.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px; /* 压缩此处间距 */
  position: relative;
  z-index: 10;
  gap: 10px;
}

.category-scroll {
  flex: 1;
  overflow: hidden;
}

.category-list {
  display: flex;
  gap: 9px;
  padding: 2px 2px 6px; /* 压缩内边距 */
}

.category-item {
  padding: 6px 14px;
  border-radius: var(--radius-xl);
  font-size: 12px;
  font-weight: 500;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 0.5px solid rgba(255, 255, 255, 0.9);
  white-space: nowrap;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.03);
}

.category-item.active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a78bfa 100%);
  color: white;
  border-color: transparent;
  box-shadow: 0 2px 7px rgba(99, 102, 241, 0.25);
  font-weight: 600;
}

/* ========================================
   工具卡片网格
   ======================================== */
.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  position: relative;
  z-index: 1;
  width: 100%;
}

.load-status {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
  padding: 12px 14px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.78);
  border: 0.5px solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 4px 14px rgba(15, 23, 42, 0.05);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  position: relative;
  z-index: 1;
}

.load-status.is-loading {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(255, 255, 255, 0.82) 100%);
}

.load-status.is-cache {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.12) 0%, rgba(255, 255, 255, 0.84) 100%);
}

.load-status-spinner {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 2px solid rgba(99, 102, 241, 0.2);
  border-top-color: #6366f1;
  flex-shrink: 0;
  animation: loadSpin 0.8s linear infinite;
}

.load-status-text {
  font-size: 12px;
  line-height: 1.5;
  color: #475569;
}

@keyframes loadSpin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.tool-card {
  background: rgba(255, 255, 255, 0.75);
  border-radius: var(--radius-lg);
  padding: 18px 14px;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04),
              inset 0 0.5px 0 rgba(255, 255, 255, 0.9);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
  border: 0.5px solid rgba(255, 255, 255, 0.85);
}

/* 交替卡片装饰底色 */
.tool-card:nth-child(6n+1)::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at top left, rgba(99, 102, 241, 0.06) 0%, transparent 65%);
  border-radius: var(--radius-lg);
  pointer-events: none;
}

.tool-card:nth-child(6n+2)::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at top right, rgba(236, 72, 153, 0.05) 0%, transparent 65%);
  border-radius: var(--radius-lg);
  pointer-events: none;
}

.tool-card:nth-child(6n+3)::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at bottom left, rgba(139, 92, 246, 0.06) 0%, transparent 65%);
  border-radius: var(--radius-lg);
  pointer-events: none;
}

.tool-card:nth-child(6n+4)::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at top left, rgba(245, 158, 11, 0.05) 0%, transparent 65%);
  border-radius: var(--radius-lg);
  pointer-events: none;
}

.tool-card:nth-child(6n+5)::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at bottom right, rgba(16, 185, 129, 0.05) 0%, transparent 65%);
  border-radius: var(--radius-lg);
  pointer-events: none;
}

.tool-card:nth-child(6n+6)::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at top right, rgba(59, 130, 246, 0.05) 0%, transparent 65%);
  border-radius: var(--radius-lg);
  pointer-events: none;
}

/* 卡片按压反馈 */
.tool-card:active {
  transform: scale(0.97) translateY(2px);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.03);
}

/* ---- 收藏按钮 ---- */
.tool-favorite {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 50%;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  transition: all 0.25s ease;
  border: 0.5px solid rgba(255, 255, 255, 0.8);
}

.tool-favorite:active {
  transform: scale(0.8);
}

.favorite-icon-img {
  width: 18px;
  height: 18px;
  filter: grayscale(1);
  opacity: 0.35;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.favorite-icon-img.active {
  filter: grayscale(0) drop-shadow(0 2px 6px rgba(251, 191, 36, 0.4));
  opacity: 1;
  transform: scale(1.1);
}

/* ---- 工具图标 ---- */
.tool-icon-wrapper {
  width: 60px;
  height: 60px;
  border-radius: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 11px;
  transition: transform 0.3s ease;
  position: relative;
}

/* 交替图标底色 - 已按要求去除背景和边框，保留占位逻辑 */
.tool-card:nth-child(6n+1) .tool-icon-wrapper,
.tool-card:nth-child(6n+2) .tool-icon-wrapper,
.tool-card:nth-child(6n+3) .tool-icon-wrapper,
.tool-card:nth-child(6n+4) .tool-icon-wrapper,
.tool-card:nth-child(6n+5) .tool-icon-wrapper,
.tool-card:nth-child(6n+6) .tool-icon-wrapper {
  background: transparent;
  box-shadow: none;
}

.tool-icon-img {
  width: 100%;
  height: 100%;
  border-radius: inherit;
}

.tool-icon-emoji {
  font-size: 26px;
  filter: drop-shadow(0 1.5px 3px rgba(0, 0, 0, 0.08));
}

/* ---- 工具名称与描述 ---- */
.tool-name {
  font-size: 16px;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 5px;
  letter-spacing: 0.5px;
}

.tool-desc {
  font-size: 11.5px;
  color: #94a3b8;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ---- 同步按钮容器 ---- */
.sync-buttons {
  display: flex;
  gap: 6px;
  margin-top: 9px;
}

/* ---- 同步进度按钮 ---- */
.sync-btn {
  flex: 1;
  padding: 5px 0;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
  box-shadow: 0 2px 6px rgba(99, 102, 241, 0.2);
}

.sync-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.sync-btn-text {
  font-size: 11px;
  color: #fff;
  font-weight: 500;
  letter-spacing: 0.5px;
}

/* ---- 下载记录按钮 ---- */
.download-btn {
  flex: 1;
  padding: 5px 0;
  background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
  box-shadow: 0 2px 6px rgba(245, 158, 11, 0.2);
}

.download-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.download-btn-text {
  font-size: 11px;
  color: #fff;
  font-weight: 500;
  letter-spacing: 0.5px;
}

/* ========================================
   空状态
   ======================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0 40px;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 60px;
  margin-bottom: 16px;
  opacity: 0.3;
  animation: breathe 3s ease-in-out infinite;
}

.empty-text {
  font-size: 16px;
  color: var(--text-primary);
  margin-bottom: 6px;
  font-weight: 600;
}

.empty-hint {
  font-size: 13px;
  color: var(--text-muted);
}

/* ========================================
   公告栏（保留样式，兼容旧结构）
   ======================================== */
.notice-bar {
  margin: 10px 12px;
  background: linear-gradient(90deg, #fef9c3 0%, #fef3c7 100%);
  border-radius: var(--radius-lg);
  padding: 8px 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.notice-content {
  display: flex;
  align-items: center;
  gap: 6px;
}

.notice-icon {
  font-size: 14px;
}

.notice-text {
  font-size: 13px;
  color: #92400e;
}

.notice-close {
  font-size: 16px;
  color: #92400e;
  opacity: 0.6;
}

/* 分类栏位设置按钮 */
.fab-settings {
  height: 32px;
  padding: 0 12px;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  cursor: pointer;
  border: 0.5px solid rgba(255, 255, 255, 0.9);
  gap: 4px;
  flex-shrink: 0;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  margin-bottom: 5px;
}
.fab-icon {
  width: 14px;
  height: 14px;
  opacity: 0.6;
  transition: transform 0.3s ease;
}
.fab-settings:active .fab-icon {
  transform: rotate(180deg);
}
.fab-text {
  font-size: 11px;
  color: #64748b;
  font-weight: 600;
}

/* 全站搜索容器限制 */
.global-search-container {
  max-width: 650px;
  width: 100%;
  padding: 0 16px;
  box-sizing: border-box;
}

/* 设置弹窗 */
.settings-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1300;
  opacity: 1;
  transition: opacity 0.3s ease;
}

.settings-modal-mask.closing {
  opacity: 0;
}

.settings-modal-panel {
  width: 320px;
  max-width: 90vw;
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 255, 0.98) 100%);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.15);
  padding: 24px;
  animation: scaleIn 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

.settings-modal-panel.closing {
  animation: scaleOut 0.2s ease-in forwards;
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes scaleOut {
  from { opacity: 1; transform: scale(1); }
  to { opacity: 0; transform: scale(0.9); }
}

.settings-modal-header {
