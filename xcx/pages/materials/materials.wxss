/* 自定义导航栏 */
.custom-nav {
  background: linear-gradient(180deg, #f0f4ff 0%, var(--background) 100%);
  padding: 10px 12px;
  padding-top: 60px;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  box-sizing: border-box;
  z-index: 1000;
  box-shadow: 0 4px 20px -10px rgba(0, 0, 0, 0.08);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
}

.back-btn {
  width: 32px;
  height: 32px;
  background: var(--surface);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow);
  position: relative;
  z-index: 10;
}

.back-icon {
  width: 16px;
  height: 16px;
}

.nav-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.points-badge {
  min-width: 86px;
  height: 34px;
  padding: 0 10px 0 9px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  box-shadow: 0 10px 22px -14px rgba(15, 23, 42, 0.3);
  border: 1px solid rgba(226, 232, 240, 0.9);
}

.points-badge-text {
  display: flex;
  align-items: baseline;
  gap: 2px;
}

.points-badge-value {
  font-size: 15px;
  font-weight: 800;
  color: #1e293b;
  line-height: 1;
}

.points-badge-unit {
  font-size: 10px;
  color: #64748b;
  line-height: 1;
}

.favorites-container {
  padding: 12px;
  margin-top: 124px;
}

.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.loading-text {
  font-size: 14px;
  color: var(--text-secondary);
}

.empty-icon {
  width: 60px;
  height: 60px;
  margin-bottom: 16px;
  opacity: 0.3;
}

.empty-text {
  font-size: 16px;
  color: var(--text-primary);
  margin-bottom: 6px;
}

.empty-hint {
  font-size: 13px;
  color: var(--text-secondary);
}

.favorites-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.material-card {
  min-height: 258px;
  background:
    radial-gradient(circle at top right, rgba(99, 102, 241, 0.12), transparent 36%),
    linear-gradient(145deg, rgba(255, 255, 255, 1) 0%, rgba(245, 248, 255, 0.98) 100%);
  border-radius: 24px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow:
    0 14px 30px -16px rgba(15, 23, 42, 0.18),
    inset 0 1px 0 rgba(255,255,255,0.95);
  border: 1px solid rgba(226, 232, 240, 0.75);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}

.file-mark {
  position: relative;
  width: 74px;
  height: 86px;
  border-radius: 20px;
  background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(236, 242, 255, 0.96) 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.95), 0 8px 18px -12px rgba(79, 70, 229, 0.45);
  display: flex;
  justify-content: space-between;
  flex-direction: column;
  padding: 10px;
  box-sizing: border-box;
}

.file-mark::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 22px;
  height: 22px;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.14) 0%, rgba(255,255,255,0.98) 100%);
  border-top-right-radius: 20px;
  border-bottom-left-radius: 14px;
}

.status-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}

.material-badge {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.18) 0%, rgba(59, 130, 246, 0.28) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.file-lines {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.line {
  height: 4px;
  border-radius: 999px;
  background: rgba(148, 163, 184, 0.3);
}

.line.one {
  width: 100%;
}

.line.two {
  width: 78%;
}

.line.three {
  width: 52%;
}

.badge-text {
  font-size: 12px;
  font-weight: 800;
  color: #4f46e5;
  letter-spacing: 0.5px;
}

.points-chip {
  min-width: 58px;
  padding: 8px 10px 7px;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.18) 0%, rgba(245, 158, 11, 0.26) 100%);
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 3px;
  box-sizing: border-box;
}

.points-chip-value {
  font-size: 18px;
  font-weight: 800;
  color: #b45309;
  line-height: 1;
}

.points-chip-unit {
  font-size: 10px;
  font-weight: 600;
  color: #b45309;
  line-height: 1;
}

.redeemed-chip {
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(16, 185, 129, 0.12);
}

.redeemed-chip-text {
  font-size: 11px;
  font-weight: 700;
  color: #047857;
}

.card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10px;
  margin: 16px 0 14px;
}

.item-name {
  font-size: 17px;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-desc {
  font-size: 12px;
  color: #6b7280;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.meta-tag {
  padding: 5px 9px;
  border-radius: 999px;
  background: rgba(241, 245, 249, 0.95);
  font-size: 11px;
  color: #64748b;
}

.card-footer {
  display: flex;
  gap: 10px;
}

.preview-btn,
.open-btn {
  flex: 1;
  height: 40px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-btn {
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(99, 102, 241, 0.2);
}

.preview-btn.is-disabled {
  opacity: 0.55;
}

.open-btn {
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  box-shadow: 0 10px 18px -10px rgba(79, 70, 229, 0.6);
}

.preview-btn-text {
  font-size: 13px;
  font-weight: 700;
  color: #4f46e5;
}

.open-btn-text {
  font-size: 13px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1px;
}

@media (max-width: 360px) {
  .favorites-list {
    grid-template-columns: 1fr;
  }
}
