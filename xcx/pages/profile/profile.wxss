}

.premium-input-wrapper:focus-within {
  background: #ffffff;
  border-color: #38bdf8;
  box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.08), 0 2px 6px rgba(56, 189, 248, 0.05);
}

.premium-input {
  flex: 1;
  height: 100%;
  font-size: 15px;
  color: #1e293b;
  font-weight: 500;
}

.input-placeholder {
  color: #94a3b8;
  font-weight: 400;
}

.input-suffix {
  width: 40px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-right: -5px;
  z-index: 10;
}

.suffix-icon {
  width: 22px;
  height: 22px;
  opacity: 0.6;
  transition: all 0.2s ease;
}

.input-suffix:active .suffix-icon {
  transform: scale(0.85);
  opacity: 1;
}

.btn-primary.email-login-submit {
  width: 100%;
  height: 54px;
  background: linear-gradient(135deg, #7dd3fc 0%, #0ea5e9 100%) !important;
  border-radius: 16px;
  display: flex !important;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  color: white !important;
  margin-top: 32px;
  box-shadow: 0 8px 16px -5px rgba(14, 165, 233, 0.4);
  letter-spacing: 2px;
  border: none !important;
  transition: all 0.3s ease;
}

.btn-hover {
  transform: translateY(1px) scale(0.985);
  filter: brightness(1.1);
  box-shadow: 0 4px 8px -2px rgba(14, 165, 233, 0.25) !important;
}

.form-footer {
  text-align: center;
  margin-top: 24px;
}

.footer-hint {
  font-size: 11px;
  color: #94a3b8;
  letter-spacing: 0.5px;
}

.wechat-text {
  font-size: 16px;
  font-weight: 600;
  color: white;
}

.register-link {
  text-align: center;
  font-size: 12px;
  color: var(--text-secondary);
}

.link-text {
  color: #6366f1;
  margin-left: 4px;
}

.prompt-icon {
  font-size: 40px;
  margin-bottom: 12px;
}

.prompt-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6px;
}

.prompt-desc {
  font-size: 13px;
  color: var(--text-secondary);
