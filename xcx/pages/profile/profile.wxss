/* 完善个人资料弹窗 */
.profile-setup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(12px);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  box-sizing: border-box;
  animation: fadeIn 0.3s ease forwards;
}

.profile-setup-form {
  background: linear-gradient(145deg, rgba(255, 255, 255, 1) 0%, rgba(248, 250, 255, 0.95) 100%);
  border-radius: 24px;
  padding: 32px 24px;
  width: 100%;
  box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
  animation: scaleUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes scaleUp {
  from { opacity: 0; transform: scale(0.95) translateY(10px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.setup-header {
  text-align: center;
  margin-bottom: 30px;
}

.setup-title {
  font-size: 20px;
  font-weight: 800;
  color: #1e293b;
  display: block;
  margin-bottom: 6px;
}

.setup-subtitle {
  font-size: 13px;
  color: #64748b;
  display: block;
}

.setup-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24px;
}

.avatar-btn {
  padding: 0 !important;
  margin: 0 !important;
  width: 80px !important;
  height: 80px !important;
  min-height: 80px !important;
  border-radius: 50% !important;
  background: none;
  border: none;
  position: relative;
  overflow: visible;
  line-height: normal;
  display: flex !important;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8px 16px -6px rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

.avatar-btn::after {
  display: none;
}

.setup-avatar {
  width: 80px !important;
  height: 80px !important;
  border-radius: 50% !important;
  border: 2px solid #ffffff;
  background-color: #f1f5f9;
  box-sizing: border-box;
  flex-shrink: 0;
  display: block;
}

.camera-icon-wrapper {
  position: absolute;
  bottom: 0;
  right: -4px;
  width: 28px;
  height: 28px;
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #ffffff;
  box-shadow: 0 2px 6px rgba(99, 102, 241, 0.3);
}

.camera-icon {
  font-size: 12px;
  color: white;
}

.avatar-hint {
  font-size: 12px;
  color: #94a3b8;
  margin-top: 8px;
}

.btn-group-row {
  display: flex;
  gap: 12px;
  margin-top: 30px;
}

.flex-1 {
  flex: 1;
}

.flex-2 {
  flex: 2;
}

.btn-secondary {
  height: 52px;
  background: #f1f5f9;
  border-radius: 26px;
  color: #475569;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-secondary:active {
  background: #e2e8f0;
}

/* === 3-Terminal Adaptation Patches === */
@media screen and (min-width: 500px) {
  page-container {
    left: 0 !important; right: 0 !important; margin: auto !important;
    width: var(--max-width) !important;
    max-width: var(--max-width) !important;
    background: transparent !important;
  }

  .nav-bar, .settings-modal-mask, .settings-modal-panel, .login-fullscreen, .email-login-overlay, .profile-setup-overlay, .page-bg-global {
    left: 0 !important; right: 0 !important; margin: auto !important;
    width: var(--max-width) !important;
    max-width: var(--max-width) !important;
    transform: none !important;
  }

}


/* 公告弹窗 */
.notice-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.35);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
  z-index: 30000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.notice-modal-content {
  width: 80%;
  max-width: 580rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-sizing: border-box;
  animation: scaleUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.notice-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
}

.notice-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: 1rpx;
}

.notice-body {
  padding: 10rpx 40rpx 30rpx;
  max-height: 50vh;
  box-sizing: border-box;
}

.notice-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  white-space: pre-wrap;
  text-align: justify;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  display: block;
}

.notice-footer {
  padding: 20rpx 40rpx 40rpx;
  display: flex;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  position: relative;
  z-index: 10;
}

.notice-confirm-btn {
  width: auto;
  min-width: 160rpx;
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  background: transparent;
  color: #6366f1;
  border: 2rpx solid #6366f1;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.notice-confirm-btn:active {
  transform: scale(0.95);
  background: rgba(99, 102, 241, 0.05);
}
