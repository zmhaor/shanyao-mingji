}

.menu-section {
  margin: 0 0 10px 0;
  background: white;
  border-radius: 20px;
  padding: 12px 16px 8px;
  box-shadow: 0 4px 12px -2px rgba(0, 0, 0, 0.03);
}

.section-title {
