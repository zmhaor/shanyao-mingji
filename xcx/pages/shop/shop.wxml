<view class="page-root {{isDarkMode ? 'dark-mode' : ''}}">
<!-- 自定义导航栏 -->
<view class="custom-nav">
  <view class="nav-content">
    <view class="back-btn" bindtap="onBack">
      <image src="/images/返回.png" class="back-icon" mode="aspectFit" />
    </view>
    <text class="nav-title">积分商城</text>
    <view class="points-badge" bindtap="goToInvite">
      <image src="/images/商城.png" mode="aspectFit" style="width: 12px; height: 12px;" />
      <text>{{userPoints}}</text>
    </view>
  </view>
</view>

<!-- 积分商城列表 -->
<view class="shop-container">
  <view class="shop-list" wx:if="{{shopItems.length > 0}}">
    <view class="shop-item" wx:for="{{shopItems}}" wx:key="id">
      <view class="item-image">
        <image src="/images/商城.png" mode="aspectFit" style="width: 100%; height: 100%;" />
      </view>
      <text class="item-name">{{item.name}}</text>
      <text class="item-points">{{item.points}}积分</text>
      <view class="item-btn" bindtap="onExchange" data-id="{{item.id}}">
        兑换
      </view>
    </view>
  </view>
  <view class="empty-shop" wx:else>
    <image src="/images/商城.png" mode="aspectFit" class="empty-icon" />
    <text class="empty-text">暂无可兑换的道具</text>
  </view>
</view>
</view>
