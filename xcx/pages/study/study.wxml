                <view class="info-row" style="margin-top: 6px;" wx:if="{{!tagFilter.length || tagFilterMap['function']}}">
                  <text class="tag-label green">功用</text>
                  <text class="content-text-main" decode user-select>{{item.function}}</text>
                </view>
              </block>
              <block wx:elif="{{toolType === 'zhongyao'}}">
