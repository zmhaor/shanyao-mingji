        <view class="action-sheet-section">
          <view class="action-sheet-section-title">
            <wux-icon type="ios-funnel" size="14" color="{{isDarkMode ? '#6b7280' : '#8e8e93'}}" />
            <text style="margin-left: 6px;">显示范围</text>
          </view>
