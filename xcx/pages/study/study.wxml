<wxs module="memo">
module.exports = {
  getAssociation: function(text) {
    if (!text) return '';
    // 查找"联想："后的内容
    var idx = text.indexOf('联想：');
    if (idx === -1) {
      idx = text.indexOf('联想:');
    }
    if (idx > -1) {
      return text.substring(idx);
    }
    return '';
  },
  getKoujue: function(text) {
    if (!text) return '';
    // 查找"口诀："后的内容，到"联想："或结尾
    var idx = text.indexOf('口诀：');
    if (idx === -1) {
      idx = text.indexOf('口诀:');
    }
    if (idx > -1) {
      var endIdx = text.indexOf('\n联想：');
      if (endIdx === -1) {
        endIdx = text.indexOf('\n联想:');
      }
      if (endIdx === -1) {
        endIdx = text.indexOf('联想：');
      }
      if (endIdx === -1) {
        endIdx = text.indexOf('联想:');
      }
      if (endIdx > -1) {
        return text.substring(0, endIdx);
      }
      return text;
    }
    return text;
  }
}
</wxs>

