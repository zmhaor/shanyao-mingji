  <view class="hidden-modal-content {{showFilterModal ? 'show' : ''}}" wx:if="{{showFilterModal}}">
    <view class="hidden-modal-header">
      <view class="hidden-modal-title">内容过滤与显示</view>
      <view class="hidden-modal-close" bindtap="toggleFilterModal">✕</view>
    </view>
    
    <view style="padding: 10px 20px 30px; display: flex; flex-direction: column; gap: 20px;">
      
      <!-- 显示范围 -->
      <view>
        <view style="font-size: 13px; color: var(--text-tertiary); margin-bottom: 10px; font-weight: 600;">显示范围</view>
        <view style="display: flex; gap: 8px; flex-wrap: wrap;">
          <view class="filter-modal-tag {{filterType === 'all' && !activeGroupId ? 'active' : ''}}" bindtap="setFilterAndClose" data-type="all">全部</view>
          <block wx:if="{{showLevels}}">
            <view class="filter-modal-tag {{filterType === '1' && !activeGroupId ? 'active' : ''}}" bindtap="setFilterAndClose" data-type="1">一级</view>
            <view class="filter-modal-tag {{filterType === '2' && !activeGroupId ? 'active' : ''}}" bindtap="setFilterAndClose" data-type="2">二级</view>
          </block>
