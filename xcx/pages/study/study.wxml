          <view class="group-select-info">
            <view class="group-select-title">
              <view class="level-badge small level-{{item.level}}" wx:if="{{showLevels}}">{{item.level}}</view>
              {{item.title}}
            </view>
            <view class="group-select-text {{item.text ? '' : 'group-select-text-empty'}}">{{item.text ? item.text + '...' : '占位'}}</view>
          </view>
        </view>
      </block>
    </scroll-view>

