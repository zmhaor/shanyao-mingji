        <view class="group-select-all-btn" bindtap="toggleSelectAllGroup">全选</view>
        <text class="group-select-count">{{groupSelectedCount}}</text>
      </view>
    </view>
    <text class="group-field-error" wx:if="{{groupNameError}}">请输入背诵组名称</text>

