            </view>
            <view class="read-note" wx:if="{{((!tagFilter.length || tagFilterMap['memo']) && quizItem.zhongyao_memo) || ((!tagFilter.length || tagFilterMap['association']) && quizItem.zhongyao_association)}}" style="margin-top: 10px; padding: 10px; background: #fcfcfc; border-radius: 8px; border: 0.5px solid #eee;">
               <view class="read-note-item" wx:if="{{(!tagFilter.length || tagFilterMap['memo']) && quizItem.zhongyao_memo}}">
                 <text class="note-tag yellow">口诀</text>
                 <view class="read-note-content"><text decode>{{quizItem.zhongyao_memo}}</text></view>
               </view>
               <view class="read-note-item" wx:if="{{(!tagFilter.length || tagFilterMap['association']) && quizItem.zhongyao_association}}">
                 <text class="note-tag blue">联想</text>
                 <view class="read-note-content highlight"><text decode>{{quizItem.zhongyao_association}}</text></view>
               </view>
            </view>
          </scroll-view>
        </block>
        <block wx:else>
          <view class="btn-peek" bindtap="toggleQuizPeek" wx:if="{{quizMode !== 'study'}}">{{quizShowAnswer ? '🙈 隐藏原文' : '👀 查看原文'}}</view>
          <scroll-view scroll-y class="quiz-scroll-area" enhanced="{{true}}" fast-deceleration="{{true}}" show-scrollbar="{{false}}">
            <view class="note-box show-block" wx:if="{{(quizItem.level === 1 || quizMode === 'study') && (quizItem.note || (quizItem.customNotes && quizItem.customNotes.length > 0))}}">
              <block wx:if="{{quizItem.customNotes && quizItem.customNotes.length > 0}}">
                <view class="read-note-item {{note.isTitle ? 'is-formula' : ''}}" wx:for="{{quizItem.customNotes}}" wx:key="label" wx:for-item="note">
                  <text class="note-tag {{note.color}}">{{note.label}}</text>
                  <view class="read-note-content"><text decode user-select>{{note.isTitle ? note.label : note.content}}</text></view>
                </view>
              </block>
              <block wx:else>{{quizItem.note}}</block>
