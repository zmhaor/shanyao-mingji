    <view class="group-toolbar">
      <view class="group-toolbar-row">
        <view class="group-toolbar-field group-toolbar-field-name {{groupNameError ? 'group-toolbar-field-error' : ''}}">
          <wux-icon type="ios-create" size="14" color="{{groupNameError ? '#dc2626' : '#007aff'}}" />
          <input class="group-name-input {{groupNameError ? 'group-name-input-error' : ''}}" placeholder="名称" value="{{newGroupName}}" bindinput="onGroupNameInput" focus="{{showGroupCreate}}" />
        </view>
        <view class="group-toolbar-field group-toolbar-field-search">
          <wux-icon type="ios-search" size="14" color="#8e8e93" />
          <input class="group-search-input" placeholder="筛选条文..." value="{{groupSearchText}}" bindinput="onGroupSearchInput" />
        </view>
      </view>
