      <view wx:if="{{currentTab === 'catalog' || currentTab === 'rank'}}">
        <view style="font-size: 13px; color: var(--text-tertiary); margin-bottom: 10px; font-weight: 600;">内容展示</view>
        <view style="display: flex; gap: 8px; flex-wrap: wrap;">
          <view class="filter-modal-tag" bindtap="toggleExpandAllAndClose">{{isAllExpanded ? '🙈 隐藏全部' : '👁️ 展开全部'}}</view>
        </view>
