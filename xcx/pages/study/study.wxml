    <scroll-view scroll-y class="hidden-list">
      <block wx:for="{{groupSelectItems}}" wx:key="uniqueKey">
        <view class="group-select-item {{item.selected ? 'group-select-item-active' : ''}}" 
              bindtap="toggleGroupItem" data-key="{{item.uniqueKey}}">
