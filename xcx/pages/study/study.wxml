                <wux-icon type="ios-star" size="14" color="{{filterType === '1' && !activeGroupId ? '#fff' : '#ff9500'}}" />
                <text>一级</text>
              </view>
              <view class="action-sheet-tag {{filterType === '2' && !activeGroupId ? 'active' : ''}}" bindtap="onSheetFilter" data-type="2">
                <wux-icon type="ios-star-half" size="14" color="{{filterType === '2' && !activeGroupId ? '#fff' : '#007aff'}}" />
                <text>二级</text>
              </view>
            </block>
            </view>
        </view>

