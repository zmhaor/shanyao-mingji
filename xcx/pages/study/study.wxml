                <text class="content-text-main">{{quizItem.function}}</text>
              </view>
            </view>
            <view class="note-box show-block" wx:if="{{((!tagFilter.length || tagFilterMap['formula_song']) && (quizItem.formula_song_v1 || quizItem.formula_song)) || ((!tagFilter.length || tagFilterMap['composition_memo'] || tagFilterMap['association']) && quizItem.composition_memo) || ((!tagFilter.length || tagFilterMap['function_memo'] || tagFilterMap['association']) && quizItem.function_memo)}}" style="margin-top: 8px;">
              <view class="read-note-item formula-song-item" wx:if="{{(!tagFilter.length || tagFilterMap['formula_song']) && (quizItem.formula_song_v1 || quizItem.formula_song)}}">
                <view class="formula-song-header">
                  <text class="note-tag purple">方歌</text>
                  <view class="formula-song-tabs" wx:if="{{quizItem.formula_song_v2}}">
                    <view class="formula-song-tab {{formulaSongVersions[quizItem.name] !== 'v2' ? 'active' : ''}}"
                          catchtap="toggleFormulaSongVersion" data-version="v1" data-name="{{quizItem.name}}">版本一</view>
                    <view class="formula-song-tab {{formulaSongVersions[quizItem.name] === 'v2' ? 'active' : ''}}"
                          catchtap="toggleFormulaSongVersion" data-version="v2" data-name="{{quizItem.name}}">版本二</view>
                  </view>
                </view>
                   <view class="read-note-content" style="text-align: center;">
                     <text decode user-select>{{formulaSongVersions[quizItem.name] === 'v2' && quizItem.formula_song_v2 ? quizItem.formula_song_v2 : (quizItem.formula_song_v1 || quizItem.formula_song)}}</text>
                   </view>
                 </view>
                 <view class="read-note-item" wx:if="{{(!tagFilter.length || tagFilterMap['composition_memo'] || tagFilterMap['association']) && quizItem.composition_memo}}">
                   <text class="note-tag">组记</text>
                 <view class="read-note-content"><text decode user-select>{{tagFilterMap['composition_association'] && !tagFilterMap['composition_memo'] ? memo.getAssociation(quizItem.composition_memo) || '' : (!tagFilterMap['composition_association'] && tagFilterMap['composition_memo'] ? memo.getKoujue(quizItem.composition_memo) : quizItem.composition_memo)}}</text></view>
              </view>
              <view class="read-note-item" wx:if="{{(!tagFilter.length || tagFilterMap['function_memo'] || tagFilterMap['association']) && quizItem.function_memo}}">
                <text class="note-tag yellow">功记</text>
                <view class="read-note-content"><text decode user-select>{{tagFilterMap['function_association'] && !tagFilterMap['function_memo'] ? memo.getAssociation(quizItem.function_memo) || '' : (!tagFilterMap['function_association'] && tagFilterMap['function_memo'] ? memo.getKoujue(quizItem.function_memo) : quizItem.function_memo)}}</text></view>
              </view>
            </view>
          </scroll-view>
        </block>
        <block wx:elif="{{toolType === 'zhongyao'}}">
          <view class="btn-peek" bindtap="toggleQuizPeek" wx:if="{{quizMode !== 'study'}}">{{quizShowAnswer ? '🙈 隐藏答案' : '👀 查看答案'}}</view>
          <scroll-view scroll-y class="quiz-scroll-area" wx:if="{{quizShowAnswer || quizMode === 'study'}}">
            <view class="text-box show-block">
              <view class="info-row" wx:if="{{!tagFilter.length || tagFilterMap['function']}}">
                <text class="tag-label green">功效</text>
