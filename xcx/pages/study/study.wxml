          <block wx:else>
            <view class="btn-lg btn-lg-no" bindtap="handleQuizResult" data-result="{{false}}">😵 忘啦</view>
            <view class="btn-lg btn-lg-ok" bindtap="handleQuizResult" data-result="{{true}}">😎 记得</view>
          </block>
