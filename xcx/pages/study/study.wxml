                  <wux-icon type="ios-create" size="16" color="#007aff" />
                </view>
                <view class="group-card-action-btn group-card-action-del" catchtap="deleteGroup" data-id="{{item.id}}">
                  <wux-icon type="ios-trash" size="16" color="#ff3b30" />
                </view>
              </view>
            </view>
          </view>
          <view class="action-sheet-empty-tip" wx:else>
            <text>暂无背诵组，点击"新建背诵组"创建</text>
          </view>
        </view>

        <!-- 排序方式 -->
        <view class="action-sheet-section" wx:if="{{filterType === '1' && toolType !== 'neijing' && toolType !== 'jinkui' && toolType !== 'wenbing'}}">
          <view class="action-sheet-section-title">
            <wux-icon type="ios-swap" size="14" color="{{isDarkMode ? '#6b7280' : '#8e8e93'}}" />
            <text style="margin-left: 6px;">排序方式</text>
          </view>
          <view class="action-sheet-tags">
            <view class="action-sheet-tag {{sortType === 'clause' ? 'active-sort' : ''}}" bindtap="onSheetSort" data-sort="clause">
              <wux-icon type="ios-list" size="14" color="{{sortType === 'clause' ? '#cc7a00' : '#8e8e93'}}" />
              <text>编号序</text>
            </view>
            <view class="action-sheet-tag {{sortType === 'textbook' ? 'active-sort' : ''}}" bindtap="onSheetSort" data-sort="textbook">
              <wux-icon type="ios-book" size="14" color="{{sortType === 'textbook' ? '#cc7a00' : '#8e8e93'}}" />
              <text>课本序</text>
            </view>
          </view>
        </view>

        <!-- 内容展示 -->
        <view class="action-sheet-section" wx:if="{{currentTab === 'catalog' || currentTab === 'rank'}}">
          <view class="action-sheet-section-title">
            <wux-icon type="ios-eye" size="14" color="{{isDarkMode ? '#6b7280' : '#8e8e93'}}" />
            <text style="margin-left: 6px;">内容展示</text>
          </view>
          <view class="action-sheet-tags">
            <view class="action-sheet-tag" bindtap="onSheetExpandAll">
              <wux-icon type="{{isAllExpanded ? 'ios-eye-off' : 'ios-eye'}}" size="14" color="#8e8e93" />
              <text>{{isAllExpanded ? '隐藏全部' : '展开全部'}}</text>
            </view>
          </view>
        </view>

        <!-- 方歌版本切换（仅方剂工具显示） -->
        <view class="action-sheet-section" wx:if="{{toolType === 'fangji'}}">
          <view class="action-sheet-section-title">
            <wux-icon type="ios-musical-notes" size="14" color="{{isDarkMode ? '#6b7280' : '#8e8e93'}}" />
            <text style="margin-left: 6px;">方歌版本</text>
            <text style="margin-left: 8px; font-size: 11px; color: #94a3b8;">{{formulaSongVersionSummary}}</text>
          </view>
          <view class="action-sheet-tags">
            <view class="action-sheet-tag {{formulaSongVersionSummary === '版本一' ? 'active-version' : ''}}" 
                  bindtap="onSheetFormulaSongVersion" data-version="v1">
              <text>版本一</text>
            </view>
            <view class="action-sheet-tag {{formulaSongVersionSummary === '版本二' ? 'active-version' : ''}}" 
                  bindtap="onSheetFormulaSongVersion" data-version="v2">
              <text>版本二</text>
            </view>
            <view class="action-sheet-tag {{formulaSongVersionSummary === '自定义' ? 'active-version' : ''}}" 
                  wx:if="{{formulaSongVersionSummary === '自定义'}}">
              <text>自定义</text>
            </view>
          </view>
        </view>

        <!-- 标签过滤（仅方剂和中药工具显示） -->
        <view class="action-sheet-section" wx:if="{{toolType === 'fangji' || toolType === 'zhongyao'}}">
          <view class="action-sheet-section-title">
            <wux-icon type="ios-pricetags" size="14" color="{{isDarkMode ? '#6b7280' : '#8e8e93'}}" />
            <text style="margin-left: 6px;">标签过滤</text>
            <text style="margin-left: 8px; font-size: 11px; color: #94a3b8;">{{tagFilterSheet ? tagFilterSheet.summaryText : '显示全部'}}</text>
            <view class="action-sheet-add-btn" bindtap="onSheetTagFilterReset" wx:if="{{tagFilter.length > 0}}">
              <text>重置</text>
            </view>
          </view>

          <view class="tag-filter-overview">
            <view class="tag-filter-overview-main">
              <view class="action-sheet-tag tag-filter-overview-tag {{tagFilter.length === 0 ? 'active' : ''}}" bindtap="onSheetTagFilterReset">
                <text>全部内容</text>
              </view>
              <text class="tag-filter-overview-text">{{tagFilterSheet ? tagFilterSheet.summaryText : '显示全部'}}</text>
            </view>
            <text class="tag-filter-overview-tip">先选内容类别，再决定是否带上记忆辅助</text>
          </view>

          <block wx:for="{{tagFilterSheet ? tagFilterSheet.sections : []}}" wx:key="id" wx:for-item="section">
            <view class="tag-filter-card">
              <view class="tag-filter-card-header">
                <view class="tag-filter-card-title-wrap">
                  <text class="tag-filter-card-title">{{section.title}}</text>
                  <text class="tag-filter-card-desc">{{section.description}}</text>
                </view>
                <text class="tag-filter-card-helper" wx:if="{{section.helperText}}">{{section.helperText}}</text>
              </view>

              <view class="action-sheet-tags tag-filter-tags" wx:if="{{section.items}}">
                <view
                  wx:for="{{section.items}}"
                  wx:key="key"
                  wx:for-item="tagItem"
                  class="action-sheet-tag tag-filter-tag {{tagItem.active ? 'active' : ''}}"
                  bindtap="onSheetTagFilter"
                  data-tag="{{tagItem.key}}"
                >
                  <text>{{tagItem.label}}</text>
                </view>
              </view>

              <view class="tag-filter-pair-list" wx:if="{{section.pairs}}">
                <view class="tag-filter-pair-card" wx:for="{{section.pairs}}" wx:key="id" wx:for-item="pair">
                  <view
                    class="action-sheet-tag tag-filter-pair-main {{pair.primary.active ? 'active' : ''}}"
                    bindtap="onSheetTagFilter"
                    data-tag="{{pair.primary.key}}"
                  >
                    <text class="tag-filter-pair-label">{{pair.primary.label}}</text>
                    <text class="tag-filter-pair-role">主筛选</text>
                  </view>
                  <view class="tag-filter-pair-link">
                    <text class="tag-filter-pair-arrow">-></text>
                    <text class="tag-filter-pair-link-text">联动</text>
                  </view>
                  <view
                    class="action-sheet-tag tag-filter-pair-sub {{pair.secondary.active ? 'active' : ''}} {{pair.secondary.linked ? 'tag-filter-linked' : ''}} {{pair.secondary.disabled ? 'tag-filter-disabled' : ''}}"
                    bindtap="{{pair.secondary.disabled ? '' : 'onSheetTagFilter'}}"
                    data-tag="{{pair.secondary.key}}"
                    data-group="{{pair.secondary.group}}"
                  >
                    <text class="tag-filter-pair-label">{{pair.secondary.label}}</text>
                    <text class="tag-filter-pair-role">{{pair.secondary.linked ? '跟随选中' : (pair.secondary.disabled ? '需先选主标签' : '跟随选中')}}</text>
                  </view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </scroll-view>

      <view class="action-sheet-cancel" bindtap="closeActionSheet">取消</view>
    </view>
  </view>

  </view>
</view>
