  align-items: center;
  gap: 6px;
  background: rgba(255, 149, 0, 0.08);
  border: 0.5px solid rgba(255, 149, 0, 0.2);
  border-radius: 20px;
  padding: 6px 10px 6px 8px;
  margin-left: 8px;
  transition: all 0.2s ease;
}

.group-active-pill:active {
  opacity: 0.7;
  transform: scale(0.96);
}

.group-active-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #ff9500;
  box-shadow: 0 0 6px rgba(255, 149, 0, 0.4);
  animation: pulse-glow-orange 2s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes pulse-glow-orange {
  0%, 100% { box-shadow: 0 0 6px rgba(255, 149, 0, 0.4); transform: scale(1); }
  50% { box-shadow: 0 0 10px rgba(255, 149, 0, 0.6); transform: scale(1.1); }
}

.group-active-pill .group-active-name {
  font-size: 12px;
  font-weight: 600;
  color: #ff9500;
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-active-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: rgba(255, 149, 0, 0.1);
  flex-shrink: 0;
}


.group-select-item {
  display: flex; align-items: center; min-height: 56px; padding: 10px 0; border-bottom: 0.5px solid #f2f2f7;
}
.group-select-item:active { background: rgba(0,122,255,0.04); }
.group-select-item-active { background: rgba(0,122,255,0.03); }
.group-select-check { width: 28px; font-size: 18px; color: #c7c7cc; flex-shrink: 0; text-align: center; }
.group-select-item-active .group-select-check { color: #007aff; }
.group-select-info { flex: 1; min-width: 0; }
.group-select-title {
  font-size: 14px; font-weight: 600; color: var(--text-primary);
  display: flex; align-items: center; gap: 4px;
}
.group-select-text {
  min-height: 18px; line-height: 18px; font-size: 12px; color: var(--text-tertiary); margin-top: 2px;
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 1; overflow: hidden;
}
.group-select-text-empty {
  visibility: hidden;
}



