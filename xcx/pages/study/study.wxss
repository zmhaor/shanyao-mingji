  background: #fee2e2;
}

/* === 自定义背诵组样式 === */
.group-toggle-btn {
  padding: 5px 10px; border-radius: 15px; font-size: 11px; font-weight: 600;
  background: #e5e5ea; color: #8e8e93; transition: all 0.2s; white-space: nowrap;
}
.group-toggle-btn.active {
  background: #007aff; color: #fff; box-shadow: 0 2px 5px rgba(0,122,255,0.3);
}
.group-toggle-btn:active { opacity: 0.7; }

.group-active-bar {
  display: flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg, rgba(0,122,255,0.06), rgba(88,86,214,0.06));
  border: 0.5px solid rgba(0,122,255,0.15); border-radius: 10px;
  padding: 10px 14px; margin-top: 8px;
}
.group-active-icon-wrap {
  width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;
}
.group-active-icon {
  width: 8px; height: 8px; border-radius: 50%;
  background: #007aff;
  box-shadow: 0 0 6px rgba(0,122,255,0.4);
  animation: pulse-glow 2s ease-in-out infinite;
}
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 6px rgba(0,122,255,0.4); transform: scale(1); }
  50% { box-shadow: 0 0 10px rgba(0,122,255,0.6); transform: scale(1.1); }
}
.group-active-name { font-size: 13px; font-weight: 700; color: #007aff; flex: 1; }
.group-active-exit {
  display: flex; align-items: center; gap: 4px;
  font-size: 12px; font-weight: 600; color: #ff3b30;
  background: rgba(255,59,48,0.08); padding: 5px 10px; border-radius: 8px; flex-shrink: 0;
  transition: all 0.2s ease;
}
.exit-text { font-size: 12px; }
.exit-icon {
  width: 10px; height: 10px; position: relative;
}
.exit-icon::before, .exit-icon::after {
  content: ''; position: absolute; top: 50%; left: 50%;
  width: 10px; height: 1.5px; background: #ff3b30; border-radius: 1px;
}
.exit-icon::before { transform: translate(-50%, -50%) rotate(45deg); }
.exit-icon::after { transform: translate(-50%, -50%) rotate(-45deg); }
.group-active-exit:active { opacity: 0.6; transform: scale(0.95); }

/* 背诵组激活胶囊提示 */
.group-active-pill {
